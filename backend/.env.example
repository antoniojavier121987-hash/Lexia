# --- Base de datos: Supabase Postgres ---
# La consigues en tu proyecto de Supabase -> Project Settings -> Database
# -> Connection string (elige el modo "Session", puerto 5432 o el pooler 6543)
DATABASE_URL=postgresql://postgres:[email protected]:5432/postgres

# --- Supabase Storage (para los PDFs/imágenes de contratos) ---
# SUPABASE_URL: Project Settings -> API -> Project URL
# SUPABASE_SERVICE_KEY: Project Settings -> API -> service_role key
#   (¡OJO! usa la "service_role", NUNCA la "anon" key, en el backend)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=contracts

# --- Motor de IA ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Autenticación ---
# Genera un valor con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-valor-largo-y-secreto
JWT_EXPIRE_MINUTES=1440

MAX_UPLOAD_SIZE_MB=20

# Render la asigna automáticamente, no hace falta configurarla a mano
PORT=8000
